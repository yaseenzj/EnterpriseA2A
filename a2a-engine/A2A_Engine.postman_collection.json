{
  "info": {
    "_postman_id": "e0e4c6e1-92b8-4c3d-b4b9-123456789abc",
    "name": "A2A Engine Workflow",
    "description": "Postman collection for A2A Engine API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"bearer_token\", jsonData.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8010/api/v1/auth/token",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8010",
          "path": [
            "api",
            "v1",
            "auth",
            "token"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Orchestrate (Book & Lunch)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"thread_id\", jsonData.thread_id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"request_text\": \"Book Room A and order 10 premium lunches\"\n}"
        },
        "url": {
          "raw": "http://localhost:8010/api/v1/orchestrate",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8010",
          "path": [
            "api",
            "v1",
            "orchestrate"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Approve Pending Workflow",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"thread_id\": \"{{thread_id}}\",\n    \"approved_by\": \"mgr_alex\"\n}"
        },
        "url": {
          "raw": "http://localhost:8010/api/v1/webhook/approve",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8010",
          "path": [
            "api",
            "v1",
            "webhook",
            "approve"
          ]
        }
      },
      "response": []
    }
  ]
}
